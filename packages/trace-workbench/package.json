{
  "name": "@adaptive-agent/trace-workbench",
  "version": "0.1.0",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "sh -c 'bun run dev:api & bun run dev:web; wait'",
    "dev:api": "bun --watch src/server.ts",
    "dev:web": "vite --host 0.0.0.0",
    "build": "vite build && bun build ./src/server.ts --outdir dist/server --target bun",
    "start": "bun run ./dist/server/server.js",
    "typecheck": "bunx svelte-check --tsconfig ./tsconfig.json && bunx tsc --noEmit"
  },
  "dependencies": {
    "@adaptive-agent/trace-session": "workspace:*",
    "@sveltejs/vite-plugin-svelte": "^6.1.0",
    "@tailwindcss/vite": "^4.1.11",
    "dompurify": "^3.2.6",
    "echarts": "^5.6.0",
    "marked": "^15.0.12",
    "pg": "^8.20.0",
    "svelte": "^5.35.0",
    "tailwindcss": "^4.1.11",
    "vite": "^7.0.2"
  },
  "devDependencies": {
    "@tsconfig/svelte": "^5.0.4",
    "@types/node": "^25.5.2",
    "bun-types": "^1.3.5",
    "svelte-check": "^4.2.2",
    "typescript": "^5.8.3"
  }
}
