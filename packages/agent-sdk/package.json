{
  "name": "@adaptive-agent/agent-sdk",
  "version": "0.1.0",
  "license": "MIT",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "bin": {
    "adaptive-agent": "./dist/adaptive-agent.js",
    "adaptive-agent-tui": "./dist/adaptive-agent-tui.js",
    "adaptive-agent-gaia-eval": "./dist/evaluate-gaia-jsonl.js"
  },
  "scripts": {
    "build": "bun build ./src/index.ts ./src/adaptive-agent.ts ./src/adaptive-agent-tui.ts ./src/evaluate-gaia-jsonl.ts --outdir dist --target bun",
    "adaptive-agent": "bun run ./dist/adaptive-agent.js",
    "adaptive-agent:tui": "bun run ./src/adaptive-agent-tui.ts",
    "link:global": "bun run ./scripts/link-global.ts",
    "test": "bunx vitest run",
    "typecheck": "bunx tsc --noEmit"
  },
  "dependencies": {
    "@adaptive-agent/core": "workspace:*",
    "@earendil-works/pi-tui": "^0.75.4",
    "ajv": "^8.17.1",
    "chalk": "^5.5.0",
    "marked": "^15.0.12",
    "marked-terminal": "^7.3.0",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@types/pg": "^8.20.0",
    "bun-types": "^1.3.5",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  }
}
