#!/usr/bin/env bash
# Orb setup for the AdaptiveAgent Bun + TypeScript monorepo.
# Runs once in a fresh orb before Amp starts working. Must be non-interactive
# and safe to rerun. See https://ampcode.com/manual/orbs
#
# Orbs run this as a non-root user. Sudo is used only for apt-get. Postgres is
# run as a user-owned local cluster (initdb + pg_ctl) to avoid systemd and the
# missing snakeoil TLS cert that breaks the Debian default cluster on orbs.
set -euo pipefail

cd "$(dirname "$0")/.."

log() { printf '>>> %s\n' "$*"; }
export DEBIAN_FRONTEND=noninteractive

# ─── Bun ────────────────────────────────────────────────────────────────────
# Bun ships in orbs, but install it if missing so this also works elsewhere.
if ! command -v bun >/dev/null 2>&1; then
  log "Installing Bun"
  curl -fsSL https://bun.sh/install | bash
  export BUN_INSTALL="${BUN_INSTALL:-$HOME/.bun}"
  export PATH="$BUN_INSTALL/bin:$PATH"
fi
log "Bun $(bun --version) at $(command -v bun)"

# ─── Node 22 ─────────────────────────────────────────────────────────────────
# trace-workbench:typecheck runs svelte-check, whose bin shebang is
# #!/usr/bin/env node and uses node:util.styleText (Node 22+). Orbs ship Node 20
# at /usr/local/bin/node, which shadows any apt-installed node. So after
# installing Node 22 we force the symlink at /usr/local/bin/node.
NODE_MIN=22
node_meets() { command -v node >/dev/null 2>&1 && node -e "process.exit(process.versions.major >= ${NODE_MIN} ? 0 : 1)" 2>/dev/null; }
if ! node_meets; then
  log "Installing Node ${NODE_MIN} via NodeSource"
  curl -fsSL "https://deb.nodesource.com/setup_${NODE_MIN}.x" | sudo -E bash -
  sudo apt-get install -y nodejs
  # NodeSource installs /usr/bin/node; /usr/local/bin/node (v20) shadows it.
  if ! node_meets; then
    log "Shadowing /usr/local/bin/node with NodeSource node"
    sudo ln -sf /usr/bin/node /usr/local/bin/node
    sudo ln -sf /usr/bin/npm /usr/local/bin/npm 2>/dev/null || true
    sudo ln -sf /usr/bin/npx /usr/local/bin/npx 2>/dev/null || true
  fi
fi
log "Node $(node --version) at $(command -v node)"

# ─── Dependencies ───────────────────────────────────────────────────────────
# Lockfile + patchedDependencies (patches/@openrouter/sdk) apply automatically.
log "Installing dependencies (frozen lockfile)"
bun install --frozen-lockfile

# ─── Postgres (user-owned local cluster) ────────────────────────────────────
# The agent runtime, trace-session, and trace-workbench read DATABASE_URL. Tests
# use injected clients and need no live server, but the runtime does. We avoid
# the Debian systemd cluster (broken on orbs by a missing snakeoil cert) and
# instead initdb a local data dir owned by this user, tuned for speed.
if ! command -v psql >/dev/null 2>&1; then
  log "Installing postgresql via apt-get"
  sudo apt-get update -y
  sudo apt-get install -y postgresql postgresql-contrib
fi

PGVERSION="$(ls /usr/lib/postgresql | sort -V | tail -1)"
PGBIN="/usr/lib/postgresql/${PGVERSION}/bin"
if [ ! -x "$PGBIN/initdb" ]; then
  echo "initdb not found at $PGBIN; aborting Postgres setup" >&2
  exit 1
fi

PGDATA="${PGDATA:-$HOME/.local/pgdata}"
PGLOG="${PGLOG:-$HOME/.local/pg.log}"

if [ ! -d "$PGDATA" ]; then
  log "Initializing local cluster at $PGDATA"
  mkdir -p "$(dirname "$PGDATA")"
  "$PGBIN/initdb" -D "$PGDATA" --auth=trust --no-locale -E UTF8
fi

# Tune for speed over durability (ephemeral orb). Last value wins, so append.
{
  echo "fsync = off"
  echo "synchronous_commit = off"
  echo "full_page_writes = off"
  echo "ssl = off"
  echo "listen_addresses = '127.0.0.1'"
  echo "port = 5432"
} >> "$PGDATA/postgresql.conf"

# Start (or restart) the local cluster as this user. Not root, no systemd.
if "$PGBIN/pg_ctl" -D "$PGDATA" status >/dev/null 2>&1; then
  log "Postgres already running, restarting to pick up conf"
  "$PGBIN/pg_ctl" -D "$PGDATA" -l "$PGLOG" restart -w
else
  log "Starting local Postgres cluster"
  "$PGBIN/pg_ctl" -D "$PGDATA" -l "$PGLOG" start -w
fi

# Wait for readiness (max ~15s).
for _ in $(seq 1 30); do
  if pg_isready -q -h 127.0.0.1 -p 5432; then break; fi
  sleep 0.5
done
pg_isready -h 127.0.0.1 -p 5432

# ─── Database / role ────────────────────────────────────────────────────────
# Match postgres.sh: user=adaptive, password=adaptive, db=adaptive_agent.
# initdb made this user a superuser; connect via trust over TCP. The password is
# only for connection-string compatibility (trust ignores it locally).
PGPASS="adaptive"
PGUSER_LOCAL="$(id -un)"
psql -h 127.0.0.1 -p 5432 -U "$PGUSER_LOCAL" -d postgres -v ON_ERROR_STOP=1 <<SQL
DO \$\$ BEGIN
  IF NOT EXISTS (SELECT 1 FROM pg_roles WHERE rolname = 'adaptive') THEN
    CREATE ROLE adaptive LOGIN PASSWORD '${PGPASS}';
  END IF;
END \$\$;
SELECT 'CREATE DATABASE adaptive_agent OWNER adaptive'
  WHERE NOT EXISTS (SELECT 1 FROM pg_database WHERE datname = 'adaptive_agent')\gexec
GRANT ALL PRIVILEGES ON DATABASE adaptive_agent TO adaptive;
SQL

DATABASE_URL="postgres://adaptive:${PGPASS}@127.0.0.1:5432/adaptive_agent"
export DATABASE_URL

# Apply core runtime migrations. Idempotent (all statements use IF NOT EXISTS).
log "Applying core runtime migrations"
for migration in packages/core/migrations/*.sql; do
  log "  applying $migration"
  PGPASSWORD="${PGPASS}" psql -v ON_ERROR_STOP=1 \
    -h 127.0.0.1 -p 5432 -U adaptive -d adaptive_agent -f "$migration"
done

# ─── Env file ───────────────────────────────────────────────────────────────
# Copy template without clobbering an existing local env, then ensure
# DATABASE_URL is present so the runtime defaults to postgres mode.
if [ ! -f .env.local ]; then
  log "Copying .env.example -> .env.local"
  cp -- .env.example .env.local
fi
if ! grep -q '^DATABASE_URL=' .env.local; then
  log "Appending DATABASE_URL to .env.local"
  echo "DATABASE_URL=${DATABASE_URL}" >> .env.local
fi

# ─── Orb-scoped agent guidance ──────────────────────────────────────────────
# Notes the agent needs inside the orb: how to run things, where the DB lives.
mkdir -p "$HOME/.config/amp"
cat > "$HOME/.config/amp/AGENTS.md" <<MD
# AdaptiveAgent orb notes

## Runtime
- Bun + TypeScript monorepo. Workspaces live in \`packages/*\`.
- Node 22 is installed at /usr/local/bin/node (required by svelte-check).
- Install is already done (\`.agents/setup\`). Do not re-run \`bun install\` unless
  \`bun.lock\` changes.
- Postgres runs as a user-owned local cluster (not systemd):
  - data dir: \`$PGDATA\`
  - log: \`$PGLOG\`
  - \`${PGBIN}/pg_ctl -D "${PGDATA}" status\` to check, \`... stop\` / \`... start\` to manage.
  - Tuned for speed (fsync off, ssl off) — ephemeral, not durable.
  - \`DATABASE_URL=${DATABASE_URL}\`
  - Also written to \`.env.local\`.
  - Core runtime migrations in \`packages/core/migrations/*.sql\` are applied.

## Verification commands (Bun-native)
- Core tests:        \`bun run core:test\`  (or \`bunx vitest run\` from packages/core)
- Agent SDK tests:   \`bun run agent:test\`
- Trace tests:       \`bun run trace-session:test\`
- Trace workbench:   \`bun run trace-workbench:typecheck\`
- Typecheck a pkg:   \`cd packages/<pkg> && bunx tsc --noEmit\`
- Run the CLI:        \`bun run ./packages/agent-sdk/src/adaptive-agent.ts\`

## Boundaries (from repo AGENTS.md)
- \`@adaptive-agent/core\` owns durable runtime semantics; must not import
  \`@adaptive-agent/agent-sdk\`.
- Agent SDK owns CLI workflows, spec loading, coordinator prompts.
- Preserve terminology from agen-spec-v1.5.md / agen-contracts-v1.5.md.
MD

log "Setup complete."
log "DATABASE_URL=${DATABASE_URL}"
log "Node $(node --version), Bun $(bun --version)"
log "Run tests with: bun run core:test && bun run agent:test && bun run trace-session:test && bun run trace-workbench:typecheck"
