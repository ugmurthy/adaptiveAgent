{
  "name": "adaptive-agent-monorepo",
  "version": "0.0.1",
  "license": "MIT",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "core:build": "bun run --cwd ./packages/core build",
    "core:test": "bun run --cwd ./packages/core test",
    "agent:build": "bun run --cwd ./packages/agent-sdk build",
    "agent:test": "bun run --cwd ./packages/agent-sdk test",
    "agent:tui": "bun run ./packages/agent-sdk/src/adaptive-agent-tui.ts",
    "trace-session": "bun run ./packages/trace-session/src/trace-session.ts",
    "trace-session:build": "bun run --cwd ./packages/trace-session build",
    "trace-session:test": "bun run --cwd ./packages/trace-session test",
    "trace-session:typecheck": "bun run --cwd ./packages/trace-session typecheck",
    "trace-workbench:dev": "bun run --cwd ./packages/trace-workbench dev",
    "trace-workbench:build": "bun run --cwd ./packages/trace-workbench build",
    "trace-workbench:start": "bun run --cwd ./packages/trace-workbench start",
    "trace-workbench:typecheck": "bun run --cwd ./packages/trace-workbench typecheck",
    "service-console:dev": "bun run --cwd ./packages/service-console dev",
    "service-console:build": "bun run --cwd ./packages/service-console build",
    "service-console:typecheck": "bun run --cwd ./packages/service-console typecheck"
  },
  "dependencies": {
    "@e2b/code-interpreter": "^2.4.0",
    "@types/marked-terminal": "^6.1.1",
    "marked": "^15.0.12",
    "marked-terminal": "^7.3.0",
    "meshapi-node-sdk": "^0.1.0"
  },
  "patchedDependencies": {
    "@openrouter/sdk@0.12.35": "patches/@openrouter%2Fsdk@0.12.35.patch"
  }
}
