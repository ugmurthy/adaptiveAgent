# ─── Model Provider API Keys ─────────────────────────────────────────────────
# At least one provider is required. Ollama needs no key.

# OpenRouter (https://openrouter.ai/keys)
OPENROUTER_API_KEY=

# Mistral (https://console.mistral.ai/api-keys)
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-2506

# Mesh (https://docs.meshapi.ai/)
MESH_API_KEY=

# Gateway JWT secret used by packages/gateway-fastify/src/start-local.ts
# GATEWAY_JWT_SECRET=adaptive-agent-local-dev-secret

# ─── Tool API Keys ──────────────────────────────────────────────────────────
# Configure `web_search` to use `brave`, `serper`, `parallel`, or `duckduckgo`.
# Configure `read_web_page` to use `parallel` extraction or direct HTTP fetch.

# WEB_SEARCH_PROVIDER=brave
# WEB_SEARCH_PROVIDER=serper
# WEB_SEARCH_PROVIDER=parallel
# WEB_SEARCH_PROVIDER=duckduckgo
# WEB_READ_PAGE_PROVIDER=parallel
# TOOL_TIMEOUT_MS=120000
# WEB_TOOL_TIMEOUT_MS=90000
# MODEL_TIMEOUT_MS=90000
# MODEL_TIMEOUT_MS=0

# Brave Search (https://api.search.brave.com/app/keys)
BRAVE_SEARCH_API_KEY=

# Serper Search (https://serper.dev/)
SERPER_API_KEY=

# Parallel Search/Extract (https://platform.parallel.ai/)
PARALLEL_API_KEY=

# Optional call-count based provider cost estimates used in trace reports.
# Provider-specific search rates override WEB_SEARCH_COST_USD_PER_REQUEST.
# BRAVE_SEARCH_COST_USD_PER_REQUEST=0.001
# SERPER_SEARCH_COST_USD_PER_REQUEST=0.001
# PARALLEL_SEARCH_COST_USD_PER_REQUEST=0.005
# PARALLEL_EXTRACT_COST_USD_PER_REQUEST=0.01
# WEB_SEARCH_COST_USD_PER_REQUEST=
# WEB_READ_PAGE_COST_USD_PER_REQUEST=

# Trace Workbench reads the same Postgres trace store as trace-session.
# TRACE_WORKBENCH_DATABASE_URL=postgres://postgres:postgres@localhost:5432/adaptive_agent
# TRACE_WORKBENCH_PORT=4767
# TRACE_WORKBENCH_HOST=0.0.0.0

# Private artifact storage (S3 in production; MinIO locally).
# Production endpoints must use HTTPS. Buckets must block all public access.
# ARTIFACT_S3_BUCKET=adaptive-agent-artifacts
# ARTIFACT_S3_REGION=us-east-1
# ARTIFACT_S3_ENDPOINT=http://localhost:9000
# ARTIFACT_S3_ACCESS_KEY_ID=minioadmin
# ARTIFACT_S3_SECRET_ACCESS_KEY=minioadmin
# ARTIFACT_S3_FORCE_PATH_STYLE=true
# ARTIFACT_S3_SERVER_SIDE_ENCRYPTION=AES256
# ARTIFACT_MAX_FILES=20
# ARTIFACT_MAX_FILE_BYTES=52428800
# ARTIFACT_MAX_TOTAL_BYTES=104857600
# ARTIFACT_RETENTION_DAYS=7
# ARTIFACT_QUARANTINE_RETENTION_DAYS=30
# ARTIFACT_ABANDONED_UPLOAD_MS=3600000
# JOB_WORKSPACE_ROOT=./var/jobs
# Profile resolution for retry, recovery, resume, and continuation: exact (default), compatible, or latest.
# `compatible` requires the active manifest entry to declare the pinned revision in `resumeCompatibleWith`.
# AGENT_PROFILE_RESOLUTION_POLICY=exact

# ─── Optional Overrides ─────────────────────────────────────────────────────
# Print the inherited environment at service startup. Secret-like values and URL passwords are redacted.
# PRINT_ENV_VARS=1
# Ollama base URL (defaults to http://localhost:11434/v1)
# OLLAMA_BASE_URL=http://localhost:11434/v1

# Default model per provider (used by the sample script)
# OLLAMA_MODEL=qwen3.5
# OPENROUTER_MODEL=anthropic/claude-sonnet-4
# MISTRAL_MODEL=mistral-large-latest
# MESH_MODEL=openai/gpt-4o
# MESH_BASE_URL=https://api.meshapi.ai/v1
# HTTP_LOG_LEVEL=info
# AGENT_LOG_LEVEL=info
# LOG_DEST=console
# LOG_DEST=file
# LOG_DEST=both
# LOG_DIR=./logs
# AGENT_MAX_STEPS=60
# TOOL_TIMEOUT_MS=120000
# Set TOOL_TIMEOUT_MS=0 to disable the default tool timeout.
# MODEL_TIMEOUT_MS=90000
# Set MODEL_TIMEOUT_MS=0 to disable the agent-side model timeout.
